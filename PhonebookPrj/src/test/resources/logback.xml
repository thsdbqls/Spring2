<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 콘솔 출력 -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%highlight(%-5level %logger - %msg%n)</pattern>
        </encoder>
    </appender>

    <!-- 로그 레벨 -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>